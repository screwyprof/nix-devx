# Example .envrc for host development
# Copy this file to .envrc and customize, or use: source_env .envrc.template

# On host: inject secrets without loading the nix shell
# (The nix shell runs inside the container via .devcontainer/.envrc)

if has sops; then
  export ANTHROPIC_AUTH_TOKEN=$(sops -d --extract '["service"]["api_key"]' ~/path/to/secrets.yaml)
fi

# Or use 1password CLI:
